class Solution {
    public int furthestDistanceFromOrigin(String moves) {
        char[] move = moves.toCharArray();

        int L = 0;
        int U = 0;
        int R = 0;
        for(char ch:move){
            if(ch == 'L')
                L++;
            else if(ch == 'R')
                R++;
            else
                U++;
        }

        return Math.abs(R - L) + U;
    }
}
